{
  "name": "rankify",
  "version": "0.1.0",
  "description": "T-Soft Akıllı Kategori Ürün Sıralama SaaS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -n api,ui -c cyan,magenta \"ts-node-dev --respawn --transpile-only src/index.ts\" \"npm run dev --prefix client\"",
    "dev:api": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:ui": "npm run dev --prefix client",
    "build": "tsc && npm run build --prefix client",
    "build:server": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@node-rs/argon2": "^2.0.2",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
